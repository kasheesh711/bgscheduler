# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Auth.js
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret
AUTH_SECRET=generate-with-openssl-rand-base64-32

# Wise API
WISE_USER_ID=your-wise-user-id
WISE_API_KEY=your-wise-api-key
WISE_NAMESPACE=begifted-education
WISE_INSTITUTE_ID=696e1f4d90102225641cc413

# Cron
CRON_SECRET=generate-a-secure-random-string

# AI scheduler
OPENAI_API_KEY=sk-...
OPENAI_SCHEDULER_MODEL=gpt-5.4-mini
ENABLE_AI_SCHEDULER=true

# Schedule emails
SCHEDULE_EMAIL_APPS_SCRIPT_URL=https://script.google.com/macros/s/your-deployment-id/exec
SCHEDULE_EMAIL_APPS_SCRIPT_SECRET=shared-secret-with-apps-script
SCHEDULE_EMAIL_SENDER_NAME=BeGifted
SCHEDULE_EMAIL_REPLY_TO=admin@your-domain.com
