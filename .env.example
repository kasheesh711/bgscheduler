# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Auth.js
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret
AUTH_SECRET=generate-with-openssl-rand-base64-32

# Wise API
WISE_USER_ID=your-wise-user-id
WISE_API_KEY=your-wise-api-key
WISE_NAMESPACE=begifted-education
WISE_INSTITUTE_ID=696e1f4d90102225641cc413

# Cron
CRON_SECRET=generate-a-secure-random-string

# AI scheduler
OPENAI_API_KEY=sk-...
OPENAI_SCHEDULER_MODEL=gpt-5.4-mini
OPENAI_SCHEDULER_SHADOW_MODEL=
OPENAI_SCHEDULER_REASONING_EFFORT=low
OPENAI_PROGRESS_TEST_MODEL=
OPENAI_COMPETITOR_INTEL_MODEL=
ENABLE_AI_SCHEDULER=true
ENABLE_COMPETITOR_AI=true

# LINE scheduler
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
ENABLE_LINE_SCHEDULER=true
LINE_VALIDATION_LEAD_EMAILS=

# Schedule emails
SCHEDULE_EMAIL_APPS_SCRIPT_URL=https://script.google.com/macros/s/your-deployment-id/exec
SCHEDULE_EMAIL_APPS_SCRIPT_SECRET=shared-secret-with-apps-script
SCHEDULE_EMAIL_BACKUP_APPS_SCRIPT_URL=https://script.google.com/macros/s/your-backup-deployment-id/exec
SCHEDULE_EMAIL_BACKUP_APPS_SCRIPT_SECRET=shared-secret-with-backup-apps-script
SCHEDULE_EMAIL_PUBLIC_BASE_URL=https://bgscheduler.vercel.app
SCHEDULE_EMAIL_SENDER_NAME=BeGifted
SCHEDULE_EMAIL_REPLY_TO=admin@your-domain.com

# Wise writeback safety switches
WISE_SESSION_OPERATIONS_VERIFIED=false
WISE_SESSION_CREATE_VERIFIED=false

# Tutor leave requests
LEAVE_REQUESTS_SPREADSHEET_ID=109o2vbmxlJ-l2U18Rs_WrjD7TMF5b6h__GiNkkQIfS8
LEAVE_REQUESTS_SHEET_NAME=Form Responses 1
LEAVE_REQUESTS_CONNECTED_EMAIL=admin-google-account-with-sheets-write-scope@example.com
SALES_DASHBOARD_CONNECTED_EMAIL=admin-google-account-with-sheets-write-scope@example.com
NEXT_PUBLIC_APP_URL=https://bgscheduler.vercel.app

# Competitor intelligence providers
APIFY_API_TOKEN=
APIFY_INSTAGRAM_ACTOR=apify/instagram-scraper
APIFY_FACEBOOK_ACTOR=apify/facebook-posts-scraper
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
