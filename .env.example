# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Auth.js
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret
AUTH_SECRET=generate-with-openssl-rand-base64-32

# Wise API
WISE_USER_ID=your-wise-user-id
WISE_API_KEY=your-wise-api-key
WISE_NAMESPACE=begifted-education
WISE_INSTITUTE_ID=696e1f4d90102225641cc413
# Default must stay false. Enabling sends Wise session-location PUTs.
ENABLE_WISE_CLASSROOM_WRITEBACK=false
# Separate incident-only gate for scripts/wise-room-conflict-repair.ts.
ENABLE_WISE_EMERGENCY_REPAIR=false

# Cron
CRON_SECRET=generate-a-secure-random-string

# Schedule emails
RESEND_API_KEY=re_xxxxxxxxx
SCHEDULE_EMAIL_FROM=BeGifted <schedule@your-domain.com>
SCHEDULE_EMAIL_REPLY_TO=admin@your-domain.com
