{
  "manifest_version": 3,
  "name": "BeGifted LINE OA Resolver",
  "description": "Search LINE OA Manager by Wise student code and capture parent chat URLs for Scheduler.",
  "version": "0.2.3",
  "permissions": ["storage", "activeTab", "scripting", "debugger"],
  "host_permissions": [
    "https://chat.line.biz/*",
    "https://bgscheduler.vercel.app/*",
    "http://localhost:*/*",
    "http://127.0.0.1:*/*"
  ],
  "action": {
    "default_title": "LINE OA Resolver",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chat.line.biz/*"],
      "js": ["candidate-utils.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
